# OpenAI-compatible model endpoint.
# Ollama default: http://127.0.0.1:11434/v1
# Tailscale/local proxy default: http://127.0.0.1:18080/v1
CAGENT_BASE_URL=http://127.0.0.1:18080/v1

# Model profiles. CAGENT_MODEL is the default daily coding model.
# CAGENT_FAST_MODEL is for cheaper/faster inspection runs.
# CAGENT_REVIEWER_MODEL is for slower higher-quality review/planning runs.
CAGENT_MODEL=qwen2.5-coder:14b-instruct-q4_K_M
CAGENT_FAST_MODEL=qwen2.5-coder:7b-instruct-q4_K_M
CAGENT_REVIEWER_MODEL=qwen3-coder:30b-a3b-q4_K_M

# Which model profile to use: default, fast, or reviewer.
CAGENT_MODEL_ROLE=default

# Shell command policy profile: inspect, test, edit, network, or deploy.
# Approval-required commands are blocked unless CAGENT_AUTO_APPROVE_SHELL=1
# or --auto-approve-shell is passed.
CAGENT_COMMAND_PROFILE=inspect
CAGENT_AUTO_APPROVE_SHELL=0

# Redact likely secrets from tool output before it is sent back to the model.
# Disable only for a reviewed one-off run with --no-redact-secrets.
CAGENT_REDACT_SECRETS=1

# Low temperature keeps coding changes deterministic.
CAGENT_TEMPERATURE=0.15

# Agent loop and tool limits.
CAGENT_MAX_STEPS=8
CAGENT_REQUEST_TIMEOUT_SECONDS=120
CAGENT_REQUEST_RETRIES=1
CAGENT_RETRY_BACKOFF_SECONDS=0.5
CAGENT_SHELL_TIMEOUT_SECONDS=30

# Optional local JSONL run logs under .cagent-runs/.
# Logs may contain model responses, tool arguments and tool output.
CAGENT_LOG_RUNS=0
